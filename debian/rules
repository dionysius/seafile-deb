#!/usr/bin/make -f

include /usr/share/dpkg/default.mk

# the bundled libevhtp (K&R-style API, oniguruma) does not compile under C23 (gcc >= 15)
export DEB_CFLAGS_MAINT_APPEND = -std=gnu17

export DH_VERBOSE = 1
MAKEFLAGS += --no-print-directory

# common locations
TMPDEB = $(CURDIR)/debian/tmp
# self-contained daemon prefix
SEAFPREFIX = /usr/lib/seafile
# seahub application tree
HUBPREFIX = /usr/lib/seahub
# throwaway prefix for the statically linked libevhtp
STAGING = $(CURDIR)/debian/staging

# steps imitate upstream's community build recipe:
# https://github.com/haiwen/seafile-docker/tree/master/build/seafile_13.0

# uv (not packaged in debian) builds seahub's python deps
UV_VERSION = 0.11.26
UV_SHA256_x86_64 = 6426a73c3837e6e2483ee344cbc00f36394d179afcba6183cb77437e67db4af0
UV_SHA256_aarch64 = befa1a59c91e96eb601b0fd9a97c03dd666f17baba644b2b4db9c59a767e387e
UV = $(CURDIR)/debian/.buildbin/uv
# the venv must match the runtime interpreter; cache inside the build tree (not the
# builder's home), real copies since that cache is thrown away
export UV_PYTHON_PREFERENCE = only-system
export UV_LINK_MODE = copy
export UV_CACHE_DIR = $(CURDIR)/debian/.uvcache

# keep npm's cache inside the build tree (not the builder's home)
export npm_config_cache = $(CURDIR)/debian/.npmcache

# --with-mysql helper; the sqlite backend is always built and is the default
MARIADB_CONFIG := $(or $(wildcard /usr/bin/mariadb_config),/usr/bin/mysql_config)

# go: caches inside the build tree, no toolchain downloads
export GOFLAGS = -mod=mod -trimpath
export GOCACHE = $(CURDIR)/debian/.gocache
export GOMODCACHE = $(CURDIR)/debian/.gomodcache
export GOTOOLCHAIN = local

# make the staged libevhtp discoverable
export CPPFLAGS += -I$(STAGING)/include
export LDFLAGS += -L$(STAGING)/lib
export PKG_CONFIG_PATH := $(STAGING)/lib/pkgconfig:$(PKG_CONFIG_PATH)
export PATH := $(CURDIR)/debian/.buildbin:$(PATH)

JOBS = $(or $(DEB_BUILD_OPTION_PARALLEL),1)

# systemd major version for service file templating (systemd.pc from systemd-dev)
SYSTEMD_MAJOR := $(shell pkgconf --modversion systemd)

# python install dir: upstream expects the versionless lib/python3/site-packages layout
PYSEAF = $(SEAFPREFIX)/lib/python3/site-packages

# statically linked go binaries: record the go toolchain source in Built-Using
BUILT_USING = $(shell dpkg-query -f '$${source:Package} (= $${source:Version})' -W $$(dpkg-query -S "$$(go env GOROOT)/bin/go" | cut -d: -f1))
# seahub's venv is compiled for the distribution python; pin the runtime to that minor
PY3_MINOR = $(shell python3 -c 'import sys; print("%d.%d" % sys.version_info[:2])')
PY3_NEXT = $(shell python3 -c 'import sys; print("%d.%d" % (sys.version_info[0], sys.version_info[1] + 1))')

%:
	dh $@

override_dh_auto_clean:
# go marks its module cache read-only, so make it writable before removing
	chmod -R u+w debian/.gocache debian/.gomodcache 2>/dev/null || true
	rm -rf $(STAGING) debian/.gocache debian/.gomodcache debian/.buildbin debian/.uvcache debian/.npmcache
	[ ! -f Makefile ] || $(MAKE) distclean || true
	rm -f fileserver/fileserver notification-server/notification-server
	rm -f debian/seafile-server.seafile-migrate.service debian/seafile-server.seaf-server.service debian/seafile-server.seaf-fileserver.service debian/seafile-server.seahub.service debian/seafile-fuse.seaf-fuse.service debian/seafile-server.seaf-notification.service debian/uv.tar.gz
	rm -rf seahub/frontend/node_modules seahub/frontend/build seahub/frontend/webpack-stats.json seahub/media/assets

override_dh_auto_configure-arch:
	mkdir -p $(STAGING) debian/.buildbin
# upstream invokes searpc-codegen.py; debian ships it as searpc-codegen
	ln -sf /usr/bin/searpc-codegen debian/.buildbin/searpc-codegen.py

# libevhtp (static, SSL unused); cmake 4 rejects its cmake_minimum_required(2.8)
	cd libevhtp && cmake -DEVHTP_DISABLE_SSL=ON -DEVHTP_BUILD_SHARED=OFF \
		-DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
		-DCMAKE_INSTALL_PREFIX=$(STAGING) -DCMAKE_INSTALL_LIBDIR=lib .
	$(MAKE) -C libevhtp -j$(JOBS)
	$(MAKE) -C libevhtp install

# seafile-server (the source root)
	./autogen.sh
	./configure --prefix=$(SEAFPREFIX) --with-mysql=$(MARIADB_CONFIG)

override_dh_auto_configure-indep:
# Build-Depends cannot express "nodejs with npm" (nodesource bundles it, debian splits it)
	@command -v npm >/dev/null || { \
		echo "ERROR: npm not found. Install nodejs from nodesource (bundles npm)"; \
		echo "or your distribution's npm package."; exit 1; }

override_dh_auto_build-arch:
	$(MAKE) -j$(JOBS)

# go components, each its own module
	cd fileserver && go build -o fileserver .
	cd notification-server && go build -o notification-server .

# fetch uv (build-only)
	curl -sSL https://github.com/astral-sh/uv/releases/download/$(UV_VERSION)/uv-$(DEB_BUILD_GNU_CPU)-unknown-$(DEB_BUILD_ARCH_OS)-$(DEB_BUILD_ARCH_LIBC).tar.gz -o debian/uv.tar.gz
	echo "$(UV_SHA256_$(DEB_BUILD_GNU_CPU)) debian/uv.tar.gz" | sha256sum -c -
	mkdir -p debian/.buildbin
	tar --strip-components=1 -C debian/.buildbin -xzf debian/uv.tar.gz uv-$(DEB_BUILD_GNU_CPU)-unknown-$(DEB_BUILD_ARCH_OS)-$(DEB_BUILD_ARCH_LIBC)/uv

# seahub frontend (webpack). CI=false keeps warnings non-fatal; source maps are
# unused and memory-hungry. Skipped if already built (dh_auto_clean removes the output).
override_dh_auto_build-indep:
	if [ ! -d seahub/frontend/build/frontend ]; then \
		cd seahub/frontend && npm ci --no-audit --no-fund && \
		CI=false GENERATE_SOURCEMAP=false NODE_OPTIONS=--max-old-space-size=4096 npm run build; \
	fi

override_dh_auto_test:
	:

# dwz cannot process the go binaries' compressed DWARF nor the prebuilt venv wheels
override_dh_dwz:
	dh_dwz -Xfileserver -Xnotification-server -Xseahub/venv

# prebuilt third-party wheels are not ours to strip (objcopy also chokes on some)
override_dh_strip:
	dh_strip -Xseahub/venv

override_dh_auto_install-arch:
	$(MAKE) install DESTDIR=$(TMPDEB) pythondir=$(PYSEAF) pyexecdir=$(PYSEAF)

# drop the go binaries next to the C daemons
	install -m 0755 fileserver/fileserver $(TMPDEB)$(SEAFPREFIX)/bin/fileserver
	install -m 0755 notification-server/notification-server $(TMPDEB)$(SEAFPREFIX)/bin/notification-server

# third-party license inventory of the linked go modules
	mkdir -p $(TMPDEB)/usr/share/doc/seafile-server
	debian/helpers/third-party-go.sh fileserver notification-server \
		| gzip -9n > $(TMPDEB)/usr/share/doc/seafile-server/THIRD-PARTY-LICENSES-go.txt.gz

# migration assets: base schema, per-version upgrade scripts, dispatcher, version stamp
	cp -a scripts/sql $(TMPDEB)$(SEAFPREFIX)/sql
	cp -a seahub/scripts/upgrade $(TMPDEB)$(SEAFPREFIX)/upgrade
	install -m 0755 debian/install/scripts/seafile-migrate $(TMPDEB)$(SEAFPREFIX)/bin/seafile-migrate
	install -m 0755 debian/install/scripts/seafile-db-upgrade $(TMPDEB)$(SEAFPREFIX)/bin/seafile-db-upgrade
	echo "$(DEB_VERSION_UPSTREAM)" > $(TMPDEB)$(SEAFPREFIX)/version

# static/dev artefacts and the upstream supervisor; systemd runs the daemons directly
	rm -rf $(TMPDEB)$(SEAFPREFIX)/include
	find $(TMPDEB)$(SEAFPREFIX) -name '*.la' -delete
	rm -f $(TMPDEB)$(SEAFPREFIX)/bin/seafile-controller

# synthesize a project from the merged upstream requirements (minus the bundled
# components), lock it and compile a relocatable venv - nothing to resolve at runtime
	mkdir -p $(TMPDEB)$(HUBPREFIX)
	{ echo '[project]'; echo 'name = "seahub-deps"'; echo 'version = "0"'; \
	  echo 'requires-python = ">=3.11"'; echo 'dependencies = ['; \
	  cat seahub/requirements.txt seafevents/requirements.txt seafdav/requirements.txt \
	    | grep -viE '^[[:space:]]*(#|wsgidav|seafobj|pillow-heif|$$)' | sed 's/.*/  "&",/'; \
	  echo '  "pyOpenSSL>=24",'; \
	  echo '  "whitenoise>=6",'; \
	  echo '  "pillow-heif>=1.1",'; \
	  echo ']'; } > $(TMPDEB)$(HUBPREFIX)/pyproject.toml
# pyOpenSSL floor: uv otherwise resolves a 22.x incompatible with current cryptography
# whitenoise (packaging addition): gunicorn serves the collected static itself
# pillow-heif floor: upstream's ==1.0.* pin neither ships wheels nor builds for current pythons
	cd $(TMPDEB)$(HUBPREFIX) && $(UV) lock --python python3
	$(UV) venv --relocatable --python python3 $(TMPDEB)$(HUBPREFIX)/venv
	cd $(TMPDEB)$(HUBPREFIX) && UV_PROJECT_ENVIRONMENT=$(TMPDEB)$(HUBPREFIX)/venv \
		$(UV) sync --frozen --no-dev --inexact
# self-contained venv (system site-packages would leak conflicts); bundle the
# pure-python pysearpc, seaserv comes via PYTHONPATH in the units
	cp -a /usr/lib/python3/dist-packages/pysearpc \
		$(TMPDEB)$(HUBPREFIX)/venv/lib/python3*/site-packages/

# third-party license inventory of the compiled venv
	$(TMPDEB)$(HUBPREFIX)/venv/bin/python debian/helpers/third-party-licenses.py \
		| gzip -9n > $(TMPDEB)/usr/share/doc/seafile-server/THIRD-PARTY-LICENSES-python.txt.gz

# seahub's migration step, invoked by the seafile-migrate unit
	install -D -m 0755 debian/install/scripts/seahub-migrate $(TMPDEB)$(HUBPREFIX)/bin/seahub-migrate

# build-only leftovers
	find $(TMPDEB)$(HUBPREFIX)/venv -name '__pycache__' -type d -prune -exec rm -rf {} + 2>/dev/null || true

# seahub tree in upstream's layout: seafdav/seafobj/objwrapper inside thirdpart,
# seafevents alongside (arch-independent, ships in seafile-server-data)
override_dh_auto_install-indep:
	mkdir -p $(TMPDEB)$(HUBPREFIX)
	cp -a seahub $(TMPDEB)$(HUBPREFIX)/seahub
	cp -a seafevents $(TMPDEB)$(HUBPREFIX)/seafevents
	cp -a seafdav/wsgidav $(TMPDEB)$(HUBPREFIX)/seahub/thirdpart/wsgidav
	cp -a seafobj/seafobj $(TMPDEB)$(HUBPREFIX)/seahub/thirdpart/seafobj
	cp -a seafobj/objwrapper $(TMPDEB)$(HUBPREFIX)/seahub/thirdpart/objwrapper

# build-only leftovers
	rm -rf $(TMPDEB)$(HUBPREFIX)/seahub/frontend/node_modules $(TMPDEB)$(HUBPREFIX)/seahub/frontend/src
	find $(TMPDEB)$(HUBPREFIX)/seahub $(TMPDEB)$(HUBPREFIX)/seafevents -name '.git*' -prune -exec rm -rf {} + 2>/dev/null || true
	find $(TMPDEB)$(HUBPREFIX)/seahub $(TMPDEB)$(HUBPREFIX)/seafevents -name '__pycache__' -type d -prune -exec rm -rf {} + 2>/dev/null || true

execute_after_dh_install-arch:
# seafile-server.install takes the whole daemon tree; seaf-fuse ships in seafile-fuse
	rm debian/seafile-server/usr/lib/seafile/bin/seaf-fuse

override_dh_installsystemd-arch:
	dh_installsystemd -pseafile-server --name=seafile-migrate --no-start seafile-migrate.service
	dh_installsystemd -pseafile-server --name=seaf-server --no-start --restart-after-upgrade seaf-server.service
# the go file server is optional (mysql backend only)
	dh_installsystemd -pseafile-server --name=seaf-fileserver --no-enable --no-start --restart-after-upgrade seaf-fileserver.service
	dh_installsystemd -pseafile-server --name=seahub --no-start --restart-after-upgrade seahub.service
# the fuse mount is optional
	dh_installsystemd -pseafile-fuse --name=seaf-fuse --no-enable --no-start --restart-after-upgrade seaf-fuse.service
# the notification server is optional (mysql backend only)
	dh_installsystemd -pseafile-server --name=seaf-notification --no-enable --no-start --restart-after-upgrade seaf-notification.service

execute_before_dh_installsystemd-arch:
	fypp -DSYSTEMD_MAJOR=$(SYSTEMD_MAJOR) debian/seafile-migrate.service.fypp debian/seafile-server.seafile-migrate.service
	fypp -DSYSTEMD_MAJOR=$(SYSTEMD_MAJOR) debian/seaf-server.service.fypp debian/seafile-server.seaf-server.service
	fypp -DSYSTEMD_MAJOR=$(SYSTEMD_MAJOR) debian/seaf-fileserver.service.fypp debian/seafile-server.seaf-fileserver.service
	fypp -DSYSTEMD_MAJOR=$(SYSTEMD_MAJOR) debian/seahub.service.fypp debian/seafile-server.seahub.service
	fypp -DSYSTEMD_MAJOR=$(SYSTEMD_MAJOR) debian/seaf-fuse.service.fypp debian/seafile-fuse.seaf-fuse.service
	fypp -DSYSTEMD_MAJOR=$(SYSTEMD_MAJOR) debian/seaf-notification.service.fypp debian/seafile-server.seaf-notification.service

override_dh_shlibdeps-arch:
# most venv wheels bundle private .so files dpkg-shlibdeps cannot resolve; compute
# deps only from the source-compiled wheels that link system libraries
	dh_shlibdeps -pseafile-server -Xseahub/venv
	find debian/seafile-server$(HUBPREFIX)/venv \( -name '_mysql*.so' -o -name '_ldap*.so' \) -print0 \
		| xargs -0 --no-run-if-empty dpkg-shlibdeps -Tdebian/seafile-server.substvars
	dh_shlibdeps -pseafile-fuse

override_dh_gencontrol:
	dh_gencontrol -- -Vmisc:Built-Using='$(BUILT_USING)' \
		-V'python3:Depends=python3 (>= $(PY3_MINOR)), python3 (<< $(PY3_NEXT))'

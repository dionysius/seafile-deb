# libevhtp: pinned to haiwen's fork tag (the distro 1.2.x has an incompatible API);
# "ignore" exempts it from the newer-than-main check. Bump the pin in the pattern.
opts="component=libevhtp, \
filenamemangle=s%.*/(\d[\d.]+)\.tar\.gz%libevhtp-$1.tar.gz%" \
  https://github.com/haiwen/libevhtp/tags \
  (?:.*/)?(1\.1\.6)\.tar\.gz ignore

version=4

# main upstream; only vX.Y.Z-server tags (vX.Y.Z-pro is the proprietary edition)
opts="filenamemangle=s%.*/v(\d[\d.]+)-server\.tar\.gz%@PACKAGE@_\$1.orig.tar.gz%" \
  https://github.com/haiwen/seafile-server/tags \
  (?:.*/)?v(\d[\d.]+)-server\.tar\.gz


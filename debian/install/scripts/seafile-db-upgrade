#!/usr/bin/env python3
# Apply upstream's ccnet + seafile schema deltas for one seafile version against this
# package's database paths, reusing the updater classes from the installed db_update_helper.py.
#
# Only ccnet and seafile are touched. seahub (and seafevents) schema is owned by django and
# applied by seahub-migrate, so running upstream's seahub.sql here would double-apply it.
#
# The backend is passed explicitly (sqlite3|mysql) rather than auto-detected: upstream's own
# detector always builds a MySQL info from env defaults, so it is effectively mysql-only and
# misreads this layout. Paths come from the environment db_update_helper reads at import:
#   CCNET_CONF_DIR, SEAFILE_DATA_DIR, SEAFILE_CENTRAL_CONF_DIR (+ SEAFILE_MYSQL_DB_* for mysql).
#
# Usage: seafile-db-upgrade <version> <sqlite3|mysql>
import glob
import os
import sys

UPGRADE_DIR = '/usr/lib/seafile/upgrade'


def main():
    if len(sys.argv) != 3:
        sys.exit('usage: seafile-db-upgrade <version> <sqlite3|mysql>')
    version, backend = sys.argv[1], sys.argv[2]

    sys.path.insert(0, UPGRADE_DIR)
    import db_update_helper as h  # reads the *_DIR paths from the environment at import time

    if backend == 'sqlite3':
        updater = h.SQLiteDBUpdater(version)
    elif backend == 'mysql':
        if not getattr(h, 'HAS_PYMYSQL', False):
            sys.exit('mysql backend requested but python pymysql is not available')
        updater = h.MySQLDBUpdater(version,
                                   h.DBUpdater.get_ccnet_mysql_info(version),
                                   h.DBUpdater.get_seafile_mysql_info(version),
                                   h.DBUpdater.get_seahub_mysql_info())
    else:
        sys.exit('unknown backend %r (expected sqlite3 or mysql)' % backend)

    sql_dir = updater.sql_dir
    applied = []
    ccnet_sql = os.path.join(sql_dir, 'ccnet.sql')
    if os.path.exists(ccnet_sql):
        updater.update_ccnet_sql(ccnet_sql)
        applied.append('ccnet.sql')
    # sqlite ships some ccnet deltas per split db file under a ccnet/ subdir
    for path in sorted(glob.glob(os.path.join(sql_dir, 'ccnet', '*.sql'))):
        updater.update_ccnet_sql(path)
        applied.append('ccnet/' + os.path.basename(path))
    seafile_sql = os.path.join(sql_dir, 'seafile.sql')
    if os.path.exists(seafile_sql):
        updater.update_seafile_sql(seafile_sql)
        applied.append('seafile.sql')

    print('seafile-db-upgrade %s (%s): applied %s'
          % (version, backend, ', '.join(applied) if applied else '(no ccnet/seafile deltas)'))


if __name__ == '__main__':
    main()

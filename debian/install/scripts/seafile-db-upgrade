#!/usr/bin/env python3
# Apply upstream's ccnet + seafile schema deltas for one version, reusing the updater
# classes from the installed db_update_helper.py.
#
# Only ccnet and seafile: seahub/seafevents schema is owned by django (seahub-migrate),
# running upstream's seahub.sql here would double-apply it. Paths and connection come
# from the environment db_update_helper reads at import: CCNET_CONF_DIR,
# SEAFILE_DATA_DIR, SEAFILE_CENTRAL_CONF_DIR, SEAFILE_MYSQL_DB_*.
#
# Usage: seafile-db-upgrade <version>
import os
import sys

UPGRADE_DIR = '/usr/lib/seafile/upgrade'


def main():
    if len(sys.argv) != 2:
        sys.exit('usage: seafile-db-upgrade <version>')
    version = sys.argv[1]

    sys.path.insert(0, UPGRADE_DIR)
    import db_update_helper as h  # reads the *_DIR paths from the environment at import time

    if not getattr(h, 'HAS_PYMYSQL', False):
        sys.exit('python pymysql is not available')
    updater = h.MySQLDBUpdater(version,
                               h.DBUpdater.get_ccnet_mysql_info(version),
                               h.DBUpdater.get_seafile_mysql_info(version),
                               h.DBUpdater.get_seahub_mysql_info())

    sql_dir = updater.sql_dir
    applied = []
    ccnet_sql = os.path.join(sql_dir, 'ccnet.sql')
    if os.path.exists(ccnet_sql):
        updater.update_ccnet_sql(ccnet_sql)
        applied.append('ccnet.sql')
    seafile_sql = os.path.join(sql_dir, 'seafile.sql')
    if os.path.exists(seafile_sql):
        updater.update_seafile_sql(seafile_sql)
        applied.append('seafile.sql')

    print('seafile-db-upgrade %s: applied %s'
          % (version, ', '.join(applied) if applied else '(no ccnet/seafile deltas)'))


if __name__ == '__main__':
    main()

#!/bin/bash
# Initialise or upgrade the seafile/ccnet databases.
#
# State model:
#   - the installed version is baked into /usr/lib/seafile/version at build time
#   - the on-disk data version is a stamp file at $SEAFILE_DATA_DIR/current_version
#     (same location and semantics as upstream's docker deployment, so the stamp
#     travels with the object store on relocation, restore or docker migration)
#   - no stamp + no data  -> initialise the schema
#   - no stamp + data     -> adopt the existing data (just write the stamp)
#   - installed == stamp  -> nothing to do
#   - installed >  stamp  -> run the upgrade scripts, update the stamp
#   - installed <  stamp  -> downgrade: refuse
#
# Handles the ccnet and seafile databases, then invokes seahub's migration step.
set -euo pipefail

INSTALLDIR=/usr/lib/seafile
STATEDIR=/var/lib/seafile
CONFDIR=/etc/seafile
CCNET="$STATEDIR/ccnet"

INSTALLED=$(cat "$INSTALLDIR/version")

# Load the seafile environment (database credentials, data dir).
if [ -f "$CONFDIR/seafile.env" ]; then
    set -a; . "$CONFDIR/seafile.env"; set +a
fi

log() { echo "seafile-migrate: $*"; }

# The DB connection and secrets are mandatory and have no defaults; the whole
# service stack gates on this unit, so an unconfigured install stops here with
# one actionable message.
missing=""
[ -n "${SEAFILE_DATA_DIR:-}" ] || missing="$missing SEAFILE_DATA_DIR (seafile.env)"
[ -n "${SEAFILE_MYSQL_DB_PASSWORD:-}" ] || missing="$missing SEAFILE_MYSQL_DB_PASSWORD (seafile.env)"
[ -n "${JWT_PRIVATE_KEY:-}" ] || missing="$missing JWT_PRIVATE_KEY (seafile.env)"
grep -q '^SECRET_KEY = ""' "$CONFDIR/seahub_settings.py" 2>/dev/null && missing="$missing SECRET_KEY (seahub_settings.py)"
if [ -n "$missing" ]; then
    log "ERROR: not configured yet:$missing"
    log "Create the databases and user, fill in the SEAFILE_MYSQL_DB_* variables and"
    log "generate the secrets (openssl rand -hex 32), then restart seafile."
    log "See https://github.com/dionysius/seafile-deb/wiki"
    exit 1
fi
STAMP="$SEAFILE_DATA_DIR/current_version"

# --- mysql helpers ----------------------------------------------------------

mysql_py() {
    # argv: <database> load <sqlfile> | <database> check; connection from SEAFILE_MYSQL_DB_* env
    python3 -c 'import os, sys
import pymysql
con = pymysql.connect(host=os.environ.get("SEAFILE_MYSQL_DB_HOST", "127.0.0.1"),
                      port=int(os.environ.get("SEAFILE_MYSQL_DB_PORT", "3306")),
                      user=os.environ.get("SEAFILE_MYSQL_DB_USER", "seafile"),
                      password=os.environ.get("SEAFILE_MYSQL_DB_PASSWORD", ""),
                      database=sys.argv[1])
cur = con.cursor()
if sys.argv[2] == "load":
    for stmt in open(sys.argv[3]).read().split(";"):
        if stmt.strip():
            cur.execute(stmt)
    con.commit()
else:
    cur.execute("SHOW TABLES")
    raise SystemExit(0 if cur.fetchone() else 1)' "$@"
}

init_mysql() {
    local ccnet_db="${SEAFILE_MYSQL_DB_CCNET_DB_NAME:-ccnet_db}"
    local seafile_db="${SEAFILE_MYSQL_DB_SEAFILE_DB_NAME:-seafile_db}"
    log "loading ccnet schema into $ccnet_db"
    mysql_py "$ccnet_db" load "$INSTALLDIR/sql/mysql/ccnet.sql"
    log "loading seafile schema into $seafile_db"
    mysql_py "$seafile_db" load "$INSTALLDIR/sql/mysql/seafile.sql"
    # NOTE: the databases and the seafile user/grants must already exist; create
    # them out of band (see the wiki) - this script only loads the schema.
}

mysql_initialised() {
    mysql_py "${SEAFILE_MYSQL_DB_SEAFILE_DB_NAME:-seafile_db}" check 2>/dev/null
}

# --- upgrade ----------------------------------------------------------------

major_minor() { echo "$1" | cut -d. -f1,2; }

run_upgrade_scripts() {
    local from="$1" to="$2"
    if [ "$(major_minor "$from")" = "$(major_minor "$to")" ]; then
        # a minor upgrade carries no ccnet/seafile schema change (upstream's minor-upgrade.sh
        # only relocates files inside an install layout this packaging does not use)
        log "minor upgrade $from -> $to: no server schema migration required"
        return 0
    fi
    # apply the ccnet/seafile schema deltas (sql/<ver>) for every major boundary crossed
    local sqlroot vdir vmm applied=0
    sqlroot="$INSTALLDIR/upgrade/sql"
    for vdir in $(ls "$sqlroot" 2>/dev/null | sort -V); do
        vmm=$(major_minor "$vdir")
        dpkg --compare-versions "$vmm" gt "$(major_minor "$from")" || continue
        dpkg --compare-versions "$vmm" le "$(major_minor "$to")" || continue
        log "applying server schema deltas for $vdir"
        if ! CCNET_CONF_DIR="$CCNET" SEAFILE_CENTRAL_CONF_DIR="$CONFDIR" \
                "$INSTALLDIR/bin/seafile-db-upgrade" "$vdir"; then
            log "ERROR: applying schema deltas for $vdir failed; restore from your backup."
            exit 1
        fi
        applied=1
    done
    [ "$applied" = 1 ] || log "major upgrade $from -> $to: no server schema deltas to apply"
}

# server (ccnet + seafile) database initialisation/upgrade
migrate_server() {
    if [ ! -f "$STAMP" ]; then
        if mysql_initialised; then
            log "existing data found without a version stamp; adopting as $INSTALLED"
        else
            log "initialising databases for $INSTALLED"
            init_mysql
            # seaf-server expects an (empty) default library template directory
            mkdir -p "$SEAFILE_DATA_DIR/library-template"
        fi
        echo "$INSTALLED" > "$STAMP"
        return 0
    fi

    local last
    last=$(cat "$STAMP")
    if [ "$last" = "$INSTALLED" ]; then
        return 0
    fi

    if dpkg --compare-versions "$INSTALLED" lt "$last"; then
        log "ERROR: installed version $INSTALLED is older than the data version $last."
        log "Downgrades are not supported. Restore a backup matching $last,"
        log "or reinstall seafile-server >= $last."
        exit 1
    fi

    log "upgrading $last -> $INSTALLED (databases are not backed up automatically)"
    run_upgrade_scripts "$last" "$INSTALLED"
    echo "$INSTALLED" > "$STAMP"
}

# --- main -------------------------------------------------------------------

migrate_server

# seahub manages its own (django) database; self-gating, django tracks applied migrations
log "running seahub migration"
/usr/lib/seahub/bin/seahub-migrate
log "done"

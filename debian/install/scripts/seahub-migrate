#!/bin/bash
# Apply seahub's database migrations (django, idempotent) and collect the static
# files. Invoked by seafile-migrate; runs from the shipped venv.
set -euo pipefail

HUB=/usr/lib/seahub
VENV="$HUB/venv"

export DJANGO_SETTINGS_MODULE=seahub.settings
# seaserv requires the conf dir at import (the data dir comes from seafile.env)
export SEAFILE_CENTRAL_CONF_DIR=/etc/seafile
export PYTHONPATH="$HUB/seahub:$HUB/seahub/thirdpart:$HUB:/usr/lib/seafile/lib/python3/site-packages"

set -a
. /etc/seafile/seafile.env
set +a

cd "$HUB/seahub"
echo "seahub-migrate: applying database migrations"
"$VENV/bin/python" manage.py migrate --noinput
# Collect the static files (with manifest) into the writable STATIC_ROOT.
echo "seahub-migrate: collecting static files"
"$VENV/bin/python" manage.py collectstatic --noinput -i admin

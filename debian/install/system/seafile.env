### Seafile server configuration and secrets ###
# This file is loaded as environment variables by all seafile systemd services.
# It corresponds to the ".env" file of the official docker deployment, minus
# every docker/compose specific setting.
# Reference: https://manual.seafile.com/13.0/config/env/
#
# The seafile systemd services are sandboxed, so paths to a local folder outside
# of the service-managed directories require additional unit directives to allow
# access. See the systemd units for details.

### Secrets ###
# Shared secret used to sign the JWT tokens exchanged between the seafile
# components (seaf-server, fileserver, notification-server, seahub). Generate
# one, e.g. `openssl rand -hex 32`. Keep it stable and private; changing it
# invalidates running sessions between components.
JWT_PRIVATE_KEY=

### Server identity ###
# Public protocol and hostname of the server, as reached by clients.
SEAFILE_SERVER_PROTOCOL=http
SEAFILE_SERVER_HOSTNAME=localhost
# Sub path the service is served under.
#SITE_ROOT=/

### Storage ###
# Object store location. When moving it outside /var/lib/seafile (e.g.
# /srv/seafile-data), the sandboxed services need write access granted via a
# drop-in for seafile, seafile-fileserver and seafile-migrate:
# ReadWritePaths=/srv/seafile-data
SEAFILE_DATA_DIR=/var/lib/seafile/seafile-data

### Database ###
# MySQL/MariaDB connection, used by all components. The databases and the user
# with grants on them must be created first (see the wiki); the services refuse
# to start until the password is set.
SEAFILE_MYSQL_DB_HOST=127.0.0.1
SEAFILE_MYSQL_DB_PORT=3306
SEAFILE_MYSQL_DB_USER=seafile
SEAFILE_MYSQL_DB_PASSWORD=
SEAFILE_MYSQL_DB_CCNET_DB_NAME=ccnet_db
SEAFILE_MYSQL_DB_SEAFILE_DB_NAME=seafile_db
SEAFILE_MYSQL_DB_SEAHUB_DB_NAME=seahub_db

### Cache backend ###
# seahub requires a cache backend. The default is a local redis. point these at
# an external cache to share it across nodes. seaf-server and the fileserver
# only support redis; CACHE_PROVIDER=memcached with MEMCACHED_HOST/MEMCACHED_PORT
# applies to seahub only.
CACHE_PROVIDER=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
#REDIS_PASSWORD=
#REDIS_MAX_CONNECTIONS=100
# Cache entry expiry in seconds.
#REDIS_EXPIRY=86400
#MEMCACHED_HOST=127.0.0.1
#MEMCACHED_PORT=11211

### File server ###
# The go fileserver (seafile-fileserver.service) serves HTTP file transfer on
# [fileserver] host:port (seafile.conf). Set false to fall back to seaf-server's
# built-in fileserver on the same address; the unit gates itself on this value.
ENABLE_GO_FILESERVER=true

### Notification server ###
# Real-time notification server (seafile-notification.service); the unit gates
# itself on this value.
ENABLE_NOTIFICATION_SERVER=true
# Listen address of the notification server. Upstream binds all interfaces;
# clients are expected to connect through the reverse proxy instead.
NOTIFICATION_SERVER_HOST=127.0.0.1
#NOTIFICATION_SERVER_PORT=8083
#NOTIFICATION_SERVER_LOG_LEVEL=info
# URL seaf-server and the file server use to reach the notification server.
INNER_NOTIFICATION_SERVER_URL=http://127.0.0.1:8083
# Public websocket URL clients connect to, normally <protocol>://<hostname>/notification
# via the reverse proxy. Client notifications stay inactive while unset.
NOTIFICATION_SERVER_URL=

### Logging ###
# Log to stdout so the journal captures everything (journalctl -u <service>);
# also switches seahub's django logging to the console.
SEAFILE_LOG_TO_STDOUT=true
# Directory for seahub's log files, only used when not logging to stdout.
#SEAHUB_LOG_DIR=
# Comma-separated debug flags for the C daemons (e.g. all).
#SEAFILE_DEBUG=

### Seahub ###
# Predefined runtime environment of the seahub service, matching the install
# layout of this packaging.
PYTHONPATH=/usr/lib/seahub/seahub:/usr/lib/seahub/seahub/thirdpart:/usr/lib/seahub:/usr/lib/seafile/lib/python3/site-packages
DJANGO_SETTINGS_MODULE=seahub.settings
# seafevents requires it at import (raises without it).
SEAHUB_DIR=/usr/lib/seahub/seahub
# seaserv requires the conf dir at import; the pipe path locates seaf-server's
# RPC socket.
SEAFILE_CENTRAL_CONF_DIR=/etc/seafile
SEAFILE_RPC_PIPE_PATH=/run/seafile

### Cluster ###
# Node name reported in metrics when running multiple servers.
#NODE_NAME=default
# Override the group table name shared with a pro/cluster setup.
#SEAFILE_MYSQL_DB_GROUP_TABLE_NAME=

### Integrations (separate services, not part of this packaging) ###
# SeaDoc online document editor.
#ENABLE_SEADOC=false
#SEADOC_SERVER_URL=
# Seafile AI server.
#ENABLE_SEAFILE_AI=false
#SEAFILE_AI_SERVER_URL=
#SEAFILE_AI_SECRET_KEY=
# seafevents configuration; the background tasks service is not packaged.
#EVENTS_CONFIG_FILE=
# Pro-only features, no effect in this community build.
#IS_PRO_VERSION=false
#ENABLE_FACE_RECOGNITION=false

### Seafile server configuration and secrets ###
# This file is loaded as environment variables by the seafile systemd service
# (and by seahub). It corresponds to the ".env" file of the official docker
# deployment, minus every docker/compose specific setting.
# Reference: https://manual.seafile.com/13.0/setup/env/
#
# The seafile systemd service is sandboxed, so paths to a local folder outside
# of the service-managed directories require additional unit directives to allow
# access. See the systemd unit for details.

### Secrets ###
# Shared secret used to sign the JWT tokens exchanged between the seafile
# components (seaf-server, fileserver, notification-server, seahub). It is
# generated automatically on first install if left empty. Keep it stable and
# private; changing it invalidates running sessions between components.
JWT_PRIVATE_KEY=

### Server identity ###
# Public protocol and hostname of the server, as reached by clients.
SEAFILE_SERVER_PROTOCOL=http
SEAFILE_SERVER_HOSTNAME=localhost
# Sub path the service is served under (default: /).
SITE_ROOT=/

### Feature toggles ###
# The go fileserver (seaf-fileserver.service) requires the MySQL/MariaDB backend and
# must be enabled manually (systemctl enable --now seaf-fileserver). With the default
# SQLite backend, seaf-server's built-in file server handles HTTP, so leave this off.
ENABLE_GO_FILESERVER=false
# Real-time notification server (requires the [notification] section in seafile.conf).
ENABLE_NOTIFICATION_SERVER=false
# WebDAV server (provided by the seahub package).
ENABLE_SEAFDAV=false

### Database backend ###
# Default is SQLite (configured in seafile.conf), which needs no settings here
# and no external service. To use MySQL/MariaDB, set the variables below and
# switch seafile.conf / seahub_settings.py to the mysql backend (see the manual).
#SEAFILE_MYSQL_DB_HOST=127.0.0.1
#SEAFILE_MYSQL_DB_PORT=3306
#SEAFILE_MYSQL_DB_USER=seafile
#SEAFILE_MYSQL_DB_PASSWORD=
#SEAFILE_MYSQL_DB_CCNET_DB_NAME=ccnet_db
#SEAFILE_MYSQL_DB_SEAFILE_DB_NAME=seafile_db
#SEAFILE_MYSQL_DB_SEAHUB_DB_NAME=seahub_db

### Cache backend ###
# seahub requires a cache backend (redis or memcached). The default is a local redis,
# provided by the redis-server dependency. Point these at an external cache to share it
# across nodes, or set CACHE_PROVIDER=memcached with MEMCACHED_HOST/MEMCACHED_PORT.
CACHE_PROVIDER=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
#REDIS_PASSWORD=
